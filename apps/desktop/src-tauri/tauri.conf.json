{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Azkar App",
  "version": "0.1.0",
  "identifier": "com.azkar.app",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../web && npm run build",
    "frontendDist": "../../web/out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Azkar App",
        "width": 400,
        "height": 700,
        "minWidth": 360,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
